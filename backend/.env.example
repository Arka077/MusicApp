# Backend Environment Variables Template
# Copy this file to '.env' and fill in your hosted credentials.

# Service Port (automatically set by Railway/Render, defaults to 3000)
PORT=3000

# Hosted MySQL Database Credentials
DB_HOST=your-mysql-db-hostname.aivencloud.com
DB_USER=your_mysql_username
DB_PASSWORD=your_mysql_password
DB_NAME=music_app

# JSON Web Token Secret (generate a secure random string, e.g. using openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here

# ImageKit Storage API Credentials (for music covers and audio uploads)
IMAGEKIT_PUBLIC_KEY=public_Kj33VpF1EDthGd+GsXQNuuj25j8=
IMAGEKIT_PRIVATE_KEY=private_e6DADJRKMpvgZYrmxgIH+9MWrZE=
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint_id/

# URL of your deployed ML Service (FastAPI running CLAP model)
ML_SERVICE_URL=https://your-ml-service.hf.space

# URL of your deployed Frontend React application (to allow CORS requests)
FRONTEND_URL=https://your-music-app.vercel.app
