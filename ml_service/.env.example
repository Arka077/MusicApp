# Machine Learning Service (FastAPI) Environment Variables Template
# Copy this file to '.env' or add these keys to your cloud provider settings.

# Cloud Qdrant database credentials
QDRANT_URL=https://your-qdrant-cluster-url.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Service port (Hugging Face Spaces automatically uses 7860, Cloud Run uses 8080)
ML_SERVICE_PORT=7860
